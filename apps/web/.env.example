# ─── Database ──────────────────────────────────────────────────────────────────
# Main connection string for the platforms internal _postbase schema
DATABASE_URL="postgresql://postbase:postbase@localhost:5432/postbase"

# Optional: Port to map to host (defaults to 5432)
# POSTGRES_PORT=5432

# ─── Authentication ────────────────────────────────────────────────────────────
# Secret key used to sign Postbase JWTs (generate with: openssl rand -base64 32)
POSTBASE_JWT_SECRET="generate-a-long-random-secret-here"

# Auth.js secret (required for dashboard login)
NEXTAUTH_SECRET="generate-a-long-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Storage (MinIO Defaults) ─────────────────────────────────────────────────
# These must match the values used in docker-compose.yml
MINIO_ROOT_USER="postbase"
MINIO_ROOT_PASSWORD="postbase_secret"

# ─── Feature Flags & Settings ─────────────────────────────────────────────────
# ENABLE_EMAILS=false
# LOG_LEVEL="info"
