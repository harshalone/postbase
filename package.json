{
  "name": "postbase",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "infra:up": "docker compose up -d postgres",
    "infra:down": "docker compose stop postgres",
    "infra:logs": "docker compose logs -f postgres",
    "db:push": "pnpm --filter web db:push",
    "db:seed": "pnpm --filter web db:seed",
    "db:studio": "pnpm --filter web db:studio"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  },
  "pnpm": {
    "overrides": {
      "@auth/core": "0.41.0"
    }
  }
}
